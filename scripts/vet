#!/usr/bin/env bash
# vet — Zero-AI-token build + test verification
# Reads commands from AGENTS.md, runs them, reports pass/fail.
# Usage: vet [--verify-code] [project-dir]
#   --verify-code: after test+build pass, run verify_imports.py (F039 real-code check)
#   REAL_CODE_VERIFY=1 env var does the same as --verify-code
#   project-dir: project root containing AGENTS.md (default: cwd)

set -euo pipefail

PROJECT_DIR=""
VERIFY_CODE=false

# ── Parse arguments ──
for arg in "$@"; do
    case "$arg" in
        --verify-code)
            VERIFY_CODE=true
            ;;
        *)
            if [[ -z "$PROJECT_DIR" ]]; then
                PROJECT_DIR="$arg"
            fi
            ;;
    esac
done

PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"
AGENTS_FILE="$PROJECT_DIR/AGENTS.md"
TEST_CMD=""
BUILD_CMD=""

# ── Check REAL_CODE_VERIFY env var ──
if [[ "${REAL_CODE_VERIFY:-}" == "1" ]]; then
    VERIFY_CODE=true
fi

# ANSI codes
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m' # No Color

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "═══ vet — Build + Test Verification ═══"
echo ""

# ── Read commands from AGENTS.md ──
if [[ -f "$AGENTS_FILE" ]]; then
    echo "  Reading commands from AGENTS.md..."

    # Parse test command: look for "Test:" or "Tests:" pattern
    while IFS= read -r line; do
        # Strip list prefix: "- Test: ...", "* Test: ..."
        stripped=$(echo "$line" | sed 's/^[[:space:]]*[-*] //')
        if [[ $stripped =~ ^(Unit\ )?Tests?:\ \`(.+)\`$ ]]; then
            TEST_CMD="${BASH_REMATCH[2]}"
            echo "    Test: $TEST_CMD"
        fi
        if [[ $stripped =~ ^(Full\ )?Build:\ \`(.+)\`$ ]]; then
            BUILD_CMD="${BASH_REMATCH[2]}"
            echo "    Build: $BUILD_CMD"
        fi
    done < "$AGENTS_FILE"
else
    echo "  ⚠ No AGENTS.md found at $AGENTS_FILE"
    exit 1
fi

# Fallback defaults if not specified
if [[ -z "$TEST_CMD" ]]; then
    # Try common defaults
    if [[ -f "$PROJECT_DIR/package.json" ]]; then
        echo "  ⚠ No test command in AGENTS.md, defaulting to npm test"
        TEST_CMD="npm test"
    elif [[ -f "$PROJECT_DIR/Cargo.toml" ]]; then
        echo "  ⚠ No test command in AGENTS.md, defaulting to cargo test"
        TEST_CMD="cargo test"
    else
        echo "  ⚠ No test command in AGENTS.md"
        exit 1
    fi
fi
if [[ -z "$BUILD_CMD" ]]; then
    if [[ -f "$PROJECT_DIR/package.json" ]]; then
        echo "  ⚠ No build command in AGENTS.md, defaulting to npm run build"
        BUILD_CMD="npm run build"
    elif [[ -f "$PROJECT_DIR/Cargo.toml" ]]; then
        echo "  ⚠ No build command in AGENTS.md, defaulting to cargo build"
        BUILD_CMD="cargo build"
    else
        echo "  ⚠ No build command in AGENTS.md"
        exit 1
    fi
fi

echo ""
ALL_PASS=true

# ── Run test suite ──
echo "  ⏳ Running test suite..."
if eval "$TEST_CMD" 2>&1; then
    echo -e "  ${GREEN}✅ Tests passed${NC}"
else
    echo -e "  ${RED}❌ Tests FAILED${NC}"
    ALL_PASS=false
fi

echo ""

# ── Run build ──
echo "  ⏳ Running build..."
if eval "$BUILD_CMD" 2>&1; then
    echo -e "  ${GREEN}✅ Build passed${NC}"
else
    echo -e "  ${RED}❌ Build FAILED${NC}"
    ALL_PASS=false
fi

echo ""

if ! $ALL_PASS; then
    echo -e "${RED}🔴 Verification FAILED${NC}"
    exit 1
fi

# ── F039: Real-code verification (--verify-code flag or REAL_CODE_VERIFY=1 env) ──
if $VERIFY_CODE; then
    # Look for verify_imports.py: project dir first, then script dir, then PATH
    VERIFY_SCRIPT=""
    if [[ -f "$PROJECT_DIR/scripts/verify_imports.py" ]]; then
        VERIFY_SCRIPT="$PROJECT_DIR/scripts/verify_imports.py"
    elif [[ -f "$SCRIPT_DIR/verify_imports.py" ]]; then
        VERIFY_SCRIPT="$SCRIPT_DIR/verify_imports.py"
    elif command -v verify_imports.py &>/dev/null; then
        VERIFY_SCRIPT="verify_imports.py"
    fi

    if [[ -z "$VERIFY_SCRIPT" ]]; then
        echo "  ⚠ verify_imports.py not found (checked project/scripts/, $SCRIPT_DIR/, and PATH)"
        exit 1
    fi
    echo "  ⏳ Verifying real code (F039)..."

    set +e
    python3 "$VERIFY_SCRIPT" "$PROJECT_DIR"
    VERIFY_EXIT=$?
    set -e

    if [[ $VERIFY_EXIT -eq 0 ]]; then
        echo -e "  ${GREEN}✅ Real-code verification passed${NC}"
    elif [[ $VERIFY_EXIT -eq 2 ]]; then
        echo -e "  ${RED}🔴 Real-code verification FAILED — tested functions missing from source${NC}"
        exit 2
    else
        echo -e "  ${RED}🔴 Real-code verification error (exit code $VERIFY_EXIT)${NC}"
        exit 1
    fi
    echo ""
fi

echo -e "${GREEN}✓ Verification passed${NC}"
exit 0
