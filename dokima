def _resolve_env_fallbacks(args):
    """Apply env var fallbacks for flags that weren't explicitly set on CLI."""
    global SKIP_AUTOFIX, FORCE_FULL, SKIP_HUMAN_GATE, RESUME
    global max_parallel_override

    # Get flag values from args (may be None if not set)
    skip_autofix = getattr(args, "skip_autofix", False)
    force_full = getattr(args, "force_full", False)
    skip_auto_archive = getattr(args, "skip_auto_archive", False)
    skip_human_gate = getattr(args, "skip_human_gate", False)
    fix_all = getattr(args, "fix_all", False)
    resume_flag = getattr(args, "resume_flag", None)
    mp = getattr(args, "max_parallel", None)

    # Env var fallbacks (flag wins if set)
    if not fix_all and os.environ.get("PANEL_FIX_ALL") == "1":
        args.fix_all = True
    if not skip_autofix and os.environ.get("PANEL_SKIP_AUTOFIX") == "1":
        skip_autofix = True
        SKIP_AUTOFIX = True
    if not force_full and os.environ.get("PANEL_FORCE_FULL") == "1":
        force_full = True
        FORCE_FULL = True
    if not skip_auto_archive and os.environ.get("PANEL_SKIP_AUTO_ARCHIVE") == "1":
        args.skip_auto_archive = True
    if not skip_human_gate and os.environ.get("PANEL_SKIP_HUMAN_GATE") == "1":
        skip_human_gate = True
        SKIP_HUMAN_GATE = True
    if mp is None:
        env_mp = os.environ.get("PANEL_MAX_PARALLEL")
        if env_mp and env_mp.isdigit():
            mp = int(env_mp)
            max_parallel_override = mp

    # Set module globals from flags
    if skip_autofix:
        SKIP_AUTOFIX = True
    if force_full:
        FORCE_FULL = True
    if skip_human_gate:
        SKIP_HUMAN_GATE = True
    if mp is not None:
        max_parallel_override = mp

    # resume flag/env fallback
    if resume_flag is not None:
        RESUME = resume_flag
    elif RESUME is None:
        if os.environ.get("PANEL_RESUME") == "1":
            RESUME = True
        elif os.environ.get("PANEL_NO_RESUME") == "1":
            RESUME = False


def _load_answers_file(answers_path):
    """Load interview state from --answers JSON file. Returns prefill string or None."""
    if not answers_path:
        return None
    try:
        with open(answers_path) as f:
            interview_state = json.load(f)
    except (FileNotFoundError, json.JSONDecodeError, IOError) as e:
        print(f"  ⚠ Failed to load answers file '{answers_path}': {e}", flush=True)
        return None
    answers_list = interview_state.get("answers", [])
    questions = interview_state.get("questions", [])
    if answers_list and questions:
        prefill = "\n".join(
            f"Clarification: {q}\nUser's answer: {a}"
            for q, a in zip(questions, answers_list)
        )
        print(f"  ✓ Loaded {len(answers_list)} answer(s) from {answers_path}", flush=True)
        return prefill
    return None


